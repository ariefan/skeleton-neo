# ============================================================================
# SIMPBB NEO - Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
DATABASE_URL=mysql://root:root@localhost:3306/simpbb_neo

# ----------------------------------------------------------------------------
# Better Auth Core
# ----------------------------------------------------------------------------
# Secret key for signing tokens (generate a random string)
BETTER_AUTH_SECRET=your-random-secret-key-min-32-chars
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Admin (Default admin account)
# ----------------------------------------------------------------------------
# The default admin user will be created automatically on first startup
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!

# ----------------------------------------------------------------------------
# Email Service (Resend)
# ----------------------------------------------------------------------------
# Get your API key from https://resend.com/api-keys
# Used for: password reset, email verification, 2FA OTP, email OTP, magic links
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM=noreply@yourdomain.com

# Development mode email settings (for testing without Resend)
# EMAIL_FROM=noreply@localhost

# ----------------------------------------------------------------------------
# SMS Service (Twilio) - For phone number OTP
# ----------------------------------------------------------------------------
# Get your credentials from https://console.twilio.com/
# Used for: phone number authentication via SMS OTP
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890

# Development mode SMS settings (console log instead of sending)
# SMS_MODE=development

# ----------------------------------------------------------------------------
# OAuth Providers (Google)
# ----------------------------------------------------------------------------
# Get your credentials from https://console.cloud.google.com/
# Go to: APIs & Services > Credentials > OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------------------------
# Captcha (reCAPTCHA v2) - Bot protection
# ----------------------------------------------------------------------------
# Get your keys from https://www.google.com/recaptcha/admin
# Create a "reCAPTCHA v2" type (not v3)
RECAPTCHA_SITE_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhY
RECAPTCHA_SECRET_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe

# For localhost testing, you can use Google's test keys:
# Site Key: 6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhY
# Secret Key: 6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe
# Note: These only work on localhost!

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Session Settings
# ----------------------------------------------------------------------------
# Session expiration in seconds (default: 7 days)
SESSION_EXPIRES_IN=604800

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
# Enable/disable features
FEATURE_MAGIC_LINK=true
FEATURE_EMAIL_OTP=true
FEATURE_PHONE_AUTH=true
FEATURE_2FA=true
FEATURE_ORGANIZATIONS=true
FEATURE_ADMIN=true
